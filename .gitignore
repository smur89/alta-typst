# macOS
.DS_Store

# Typst build output (target/ used by tooling like Makefiles)
target/

# Generated example outputs. `examples/*.pdf` is gitignored because
# top-level demo PDFs (e.g. examples/cv.pdf) are regenerated by CI
# and shipped as workflow artifacts + release assets — keeping them
# out of git avoids binary churn. Single-segment glob so per-fixture
# PDFs under `examples/tests/` are unaffected (tracked separately).
# `examples/example_full.pdf` is the explicit exception — tracked
# so the README's Gallery link resolves via raw.githubusercontent
# without a local rebuild. The negation MUST come after the broader
# ignore line. Other tracked artifacts (cv.png, preview.gif,
# example_full-*.png, thumbnail.png) aren't listed here at all.
examples/*.pdf
!examples/example_full.pdf

# Intermediate per-page PNGs that `make cv` and `make preview-gif`
# write before the rename / cleanup step. A SIGINT between compile
# and `rm -f` would otherwise leave them as untracked files.
examples/cv-*.png
examples/.preview-gif-frame-*.png

# Sed-swap temp sources created by `make cv` / `make thumbnail` /
# `make test-template`. Recipes `rm -f` them on success; under
# `.DELETE_ON_ERROR:` a compile failure also clears the typst
# output target, but the sed-source can still linger on Ctrl-C.
.cv-pdf-src.typ
.cv-png-src.typ
.thumbnail-src.typ
.thumbnail-*.png
.test-template-src.typ

# Editor / IDE
.vscode/
.idea/
*.iml
*.ipr
*.iws
out/
*.swp
