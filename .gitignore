# macOS
.DS_Store

# Typst build output (target/ used by tooling like Makefiles)
target/

# Generated example outputs.
# - `examples/example.pdf` is a transient one-page render; CI rebuilds
#   it on every push and attaches it to releases, so it stays out of
#   git to avoid binary churn.
# - `examples/example_full.pdf` and `examples/preview.png` are tracked
#   (not listed here) so the multi-page demo and the README image
#   resolve immediately on GitHub and Typst Universe without needing
#   a local rebuild.
examples/example.pdf
examples/preview-*.png

# Editor / IDE
.vscode/
.idea/
*.iml
*.ipr
*.iws
out/
*.swp
