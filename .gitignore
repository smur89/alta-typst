# macOS
.DS_Store

# Typst build output (target/ used by tooling like Makefiles)
target/

# Generated example outputs.
# - `examples/*.pdf` covers every top-level demo render (example.pdf
#   and any future `examples/*.typ` demo). CI rebuilds them on every
#   push and attaches them as workflow artifacts + release assets,
#   so they stay out of git to avoid binary churn. The `*` glob is
#   single-segment, so per-fixture PDFs under `examples/tests/` are
#   NOT matched and stay tracked (see below).
# - `examples/tests/*.pdf` is tracked (not listed here) — one
#   rendered PDF per `tests/*.typ` fixture as a visible reference
#   for each permutation of the template's output.
# - `examples/preview.png` and `examples/preview.gif` are tracked
#   (not listed here) so the README image resolves immediately on
#   GitHub and Typst Universe without needing a local rebuild.
examples/*.pdf
examples/preview-*.png

# Editor / IDE
.vscode/
.idea/
*.iml
*.ipr
*.iws
out/
*.swp
